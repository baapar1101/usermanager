client
dev tun
proto tcp-client
remote shoogle.ir 1294

redirect-gateway def1

resolv-retry infinite
nobind
persist-key
persist-tun
tun-mtu 1400
mssfix 1360

cipher AES-128-CBC
auth SHA1
remote-cert-tls server

auth-user-pass

